10. Build & Push Docker Image to ECR

#Install Docker
apt install -y docker.io
systemctl start docker
systemctl enable docker

#Set ECR URL directly
ECR_URL="145400477094.dkr.ecr.ap-south-1.amazonaws.com/prod-wordpress"
REGION="ap-south-1"
echo $ECR_URL

# Login to ECR
aws ecr get-login-password --region $REGION | \
  docker login --username AWS --password-stdin $ECR_URL

# Go to project folder
cd ~/AWS-PROJECT

# Build Docker image
docker build -t wordpress-app -f docker/Dockerfile .

#Tag image
docker tag wordpress-app:latest $ECR_URL:latest

#Push to ECR
docker push $ECR_URL:latest

#Verify image is in ECR
aws ecr list-images \
  --repository-name prod-wordpress \
  --region $REGION

